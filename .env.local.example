# ============================================
# Public site config
# ============================================
NEXT_PUBLIC_SITE_URL=https://deepshah.tech

# ============================================
# Contact form — Resend (https://resend.com)
# Server-only. Create an API key and a verified sending domain.
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Must be on a domain you've verified in Resend:
CONTACT_FROM_EMAIL=hello@deepshah.tech
# Where form submissions are delivered:
CONTACT_TO_EMAIL=deep@deepshah.tech

# ============================================
# Optional analytics (add your own integration)
# ============================================
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=deepshah.tech
